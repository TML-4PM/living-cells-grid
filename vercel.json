{
  "version": 2,
  "name": "living-cells-grid",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-T4H-System",
          "value": "living-cells-grid"
        },
        {
          "key": "X-T4H-Classification",
          "value": "PARTIAL"
        }
      ]
    }
  ]
}
